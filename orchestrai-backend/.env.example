# =============================================================================
# OrchestrAI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Groq API keys (comma-separated for automatic failover)
# Get keys at: https://console.groq.com
GROQ_API_KEYS=gsk_your_key_1,gsk_your_key_2

# Tavily search API keys (comma-separated)
# Get keys at: https://tavily.com
TAVILY_API_KEYS=tvly_your_key_1

# Optional: Frontend origin for CORS (only needed in production)
# FRONTEND_ORIGIN=https://your-frontend.example.com

# =============================================================================
# NOTE: If no keys are set, OrchestrAI automatically runs in Simulation Mode.
# All agents and UI features work without any API keys in simulation mode.
# =============================================================================
